PERSONA CONTEXT:
- Caller: {{ request.user_persona or 'a bystander' }}
- Victim: {{ request.victim or 'an adult' }}
- Setting: {{ request.setting or 'unspecified' }}
- Caller's prior first aid knowledge: {{ request.user_knowledge or 'none' }}
{% if request.time_pressure %}
